# Backend justfile

init:
    uv sync --all-groups

lint: init
    uv run ruff format src tests
    uv run ruff check --fix src tests

check: init lint
    uv run pyrefly check src

test *flags: check
    uv run pytest {{ flags }}


test-cov *flags: check
    uv run pytest --cov=src --cov-report=term-missing {{ flags }}

mk-migration name: check
    uv run alembic revision --autogenerate -m "{{ name }}"

migrate: check
    uv run alembic upgrade head

serve: check
    PYTHONPATH=src uv run uvicorn visions.main:app --host 0.0.0.0 --port 8000 --reload

generate-openapi: check
    PYTHONPATH=src uv run scripts/generate_openapi.py
